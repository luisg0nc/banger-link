# Required: Get this from @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Optional: comma-separated chat IDs the bot will respond to.
# Leave empty to allow all chats. Negative IDs (groups/supergroups) are supported.
# Example: WHITELISTED_CHAT_IDS=-1001234567890,123456789
WHITELISTED_CHAT_IDS=

# Optional: semicolon-separated domain substrings to ignore.
IGNORED_DOMAINS=

# Optional: where the SQLite DB and any runtime state live.
DATA_DIR=./data

# Optional: log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Optional: health check HTTP port (Docker healthcheck hits this)
HEALTH_PORT=8080

# Optional: Songlink/Odesli API base URL (override only if proxying or self-hosting)
SONGLINK_API_URL=https://api.song.link/v1-alpha.1/links
